{
  "name": "korea-mate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:static": "node scripts/build-static.mjs",
    "deploy": "npm run build:static && npx wrangler pages deploy out --project-name=korea-mate",
    "dev:pages": "npm run build:static && npx wrangler pages dev out",
    "start": "next start",
    "lint": "eslint",
    "test:jpeg": "node --experimental-strip-types src/lib/jpeg-strip-exif.test.ts",
    "test:photo": "node --experimental-strip-types src/lib/photo-validate.test.ts",
    "test:compress": "node --experimental-strip-types src/lib/photo-compress.test.ts",
    "test:delete": "node --experimental-strip-types src/lib/photo-delete.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "next-intl": "^4.13.0",
    "next-sitemap": "^4.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "localtunnel": "^2.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.95.0"
  }
}
