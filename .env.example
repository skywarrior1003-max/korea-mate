# ═══════════════════════════════════════════════════════════════���
#  KoreaMate — Environment Variables Template
#  실제 값은 .env.local 에 입력하세요 (절대 Git 커밋 금지)
# ════════════════════════════════════════════════════════════════

# ── AI / 데이터 API ────────────────────────────────────────���─────
GEMINI_API_KEY=your_gemini_api_key_here
TOUR_API_KEY=your_korea_tourism_org_api_key_here

# ── 광고 / 애널리틱스 ────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Cloudflare (배포) ────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# ── [Tier 1] Viator — 투어/액티비티 메인 ─────────────────────────
# Viator Partner Dashboard: https://partnerresources.viator.com
# Travelpayouts 통합 사용 시 marker 값을 VIATOR_AFFILIATE_ID 에 입력
NEXT_PUBLIC_VIATOR_AFFILIATE_ID=your_viator_pid_here

# ── [Tier 2] Booking.com — 숙박 예약 메인 ────────────────────────
# Booking.com Affiliate Partner Centre: https://spadmin.booking.com
NEXT_PUBLIC_BOOKING_HOTEL_ID=your_booking_aid_here

# ── [Tier 3] Klook — 로컬 교통/eSIM 전용 ────────────────────────
# 주의: 공항 리무진·케이블카·eSIM 구역에만 사용
NEXT_PUBLIC_KLOOK_TRANSFER_URL=https://affiliate.klook.com/sl/21FkAvj
NEXT_PUBLIC_KLOOK_ESIM_URL=https://affiliate.klook.com/sl/KiT3U74
NEXT_PUBLIC_CABLE_CAR_URL=https://affiliate.klook.com/sl/XXXXXXX
NEXT_PUBLIC_BTS_BOOKING_URL=https://weverseshop.io

# ── 일정 카드 내 제휴 링크 (itinerary 페이지 카드 스트립) ──────
NEXT_PUBLIC_VIATOR_BUSAN_URL=https://www.viator.com/en-KR/Korea/d4431-ttd/
NEXT_PUBLIC_BOOKING_BUSAN_URL=https://www.booking.com/searchresults.html?ss=Busan+Korea&aid=YOUR_AID_HERE

# ── 어드민 접근 키 ────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_KEY=km-admin-2026

# ── Supabase 자동 마이그레이션 (어드민 DB 초기화용) ──────────
# supabase.com/dashboard/account/tokens 에서 생성 후 .env.local 에만 저장
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token_here

# ── (레거시 보존) ────────────────────────────────────────────────
NEXT_PUBLIC_HOTEL_BOOKING_URL=https://your-hotel-affiliate-url
NEXT_PUBLIC_AGODA_AFFILIATE_URL=https://www.agoda.com/partners/XXXXXXX
NEXT_PUBLIC_BOOKING_COM_URL=https://www.booking.com/affiliate/XXXXXXX

# ── 명소 티켓 / 입장권 ───────────────────────────────────────────
NEXT_PUBLIC_GYEONGBOKGUNG_TICKET_URL=https://affiliate.klook.com/sl/XXXXXXX
NEXT_PUBLIC_NANTA_TICKET_URL=https://affiliate.klook.com/sl/XXXXXXX
NEXT_PUBLIC_LOTTE_WORLD_TICKET_URL=https://affiliate.klook.com/sl/XXXXXXX
NEXT_PUBLIC_EVERLAND_TICKET_URL=https://affiliate.klook.com/sl/XXXXXXX
NEXT_PUBLIC_BUSAN_AQUARIUM_TICKET_URL=https://affiliate.klook.com/sl/XXXXXXX

# ── 투어 & 당일치기 ─────────────────────────────────────────────
NEXT_PUBLIC_DMZ_TOUR_URL=https://affiliate.klook.com/sl/XXXXXXX
NEXT_PUBLIC_JEJU_TOUR_URL=https://affiliate.klook.com/sl/XXXXXXX
NEXT_PUBLIC_NAMI_TOUR_URL=https://affiliate.klook.com/sl/XXXXXXX

# ── 통신 / 유심 ──────────────────────────────────────────────────
NEXT_PUBLIC_POCKET_WIFI_URL=https://affiliate.klook.com/sl/XXXXXXX
NEXT_PUBLIC_T_MONEY_INFO_URL=https://your-t-money-affiliate-url
